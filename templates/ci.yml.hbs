name: CI Guard
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  test:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '{{nodeVersion}}'
          cache: 'npm'
      - run: npm ci
      - run: npm run lint 2>/dev/null || true
      - run: npm test
      - run: npm run build
      - name: Framework detection
        run: |
          if [ -f package.json ]; then
            if grep -q '"next"' package.json; then echo "next detected"; fi
            if grep -q '"vite"' package.json; then echo "vite detected"; fi
            if grep -q '"remix"' package.json; then echo "remix detected"; fi
          fi
